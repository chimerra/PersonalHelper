# Ключ ProxyAPI (OpenAI-совместимый): https://proxyapi.ru/docs/openai-compatible-api
# Без ключа приложение работает на локальных эвристиках (fallback).
OPENAI_API_KEY=your_proxyapi_api_key_here

# Базовый URL OpenAI-совместимого API
OPENAI_BASE_URL=https://openai.api.proxyapi.ru/v1

# Модель для структурирования текста (опционально)
OPENAI_MODEL=gpt-4o-mini
